# planwright editor/formatter baseline. shfmt reads the [*.sh] keys natively
# (its sanctioned config channel), so `mise run fmt:shell` needs no flags and
# editors agree with CI. Style: 2-space indent, indented case branches,
# binary operators (| && ||) lead continuation lines. Redirect spacing
# follows shfmt's default (no space after the operator) — recorded per the
# own-adopted-tools'-defaults doctrine note: the pre-shfmt scripts mixed both
# spacings, so the default won over a -sr deviation.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.sh]
indent_style = space
indent_size = 2
switch_case_indent = true
binary_next_line = true
